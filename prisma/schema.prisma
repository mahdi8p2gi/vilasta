// ============================================================================
//  Persian Villa & Hotel Booking Platform — Prisma Schema
//  (SQLite for local dev; the schema is PostgreSQL-ready)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
//  Users & Auth
// ---------------------------------------------------------------------------
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?
  name          String?
  password      String
  avatar        String?
  role          String    @default("customer") // guest | customer | host | admin
  bio           String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  properties     Property[]
  bookings       Booking[]
  reviews        Review[]
  favorites      Favorite[]
  notifications  Notification[]
}

// ---------------------------------------------------------------------------
//  Properties (Villa / Hotel / Apartment / Resort / Cottage)
// ---------------------------------------------------------------------------
model Property {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String // villa | hotel | apartment | resort | cottage
  status      String   @default("active") // active | pending | suspended

  // Location
  city        String
  province    String
  address     String
  lat         Float?
  lng         Float?

  // Pricing (Toman)
  pricePerNight    Float
  cleaningFee      Float  @default(0)
  serviceFee       Float  @default(0)
  weeklyDiscount   Int    @default(0) // percent
  monthlyDiscount  Int    @default(0) // percent

  // Capacity
  maxGuests  Int
  bedrooms   Int
  beds       Int
  bathrooms  Int
  size       Int? // sqm

  // Rating
  rating      Float @default(0)
  reviewCount Int   @default(0)

  // JSON-encoded arrays (SQLite friendly)
  amenities String // ["wifi","pool",...]
  images    String // ["url1","url2",...]
  rules     String // ["no-smoking",...]

  hostId String
  host   User   @relation(fields: [hostId], references: [id], onDelete: Cascade)

  bookings  Booking[]
  reviews   Review[]
  favorites Favorite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([city])
  @@index([hostId])
}

// ---------------------------------------------------------------------------
//  Bookings
// ---------------------------------------------------------------------------
model Booking {
  id         String   @id @default(cuid())
  checkIn    DateTime
  checkOut   DateTime
  guests     Int
  nights     Int
  pricePerNight Float
  cleaningFee   Float
  serviceFee    Float
  totalPrice    Float
  status     String   @default("pending") // pending | confirmed | cancelled | completed
  paymentStatus String @default("unpaid") // unpaid | paid | refunded

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
//  Reviews
// ---------------------------------------------------------------------------
model Review {
  id         String   @id @default(cuid())
  rating     Float
  comment    String
  cleanliness    Float
  communication  Float
  checkIn        Float
  accuracy       Float
  location       Float
  value          Float

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([propertyId])
}

// ---------------------------------------------------------------------------
//  Favorites
// ---------------------------------------------------------------------------
model Favorite {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, propertyId])
}

// ---------------------------------------------------------------------------
//  Destinations & Categories
// ---------------------------------------------------------------------------
model Destination {
  id            String   @id @default(cuid())
  name          String
  province      String
  image         String
  propertyCount Int      @default(0)
  createdAt     DateTime @default(now())
}

model Category {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  icon          String
  image         String
  propertyCount Int      @default(0)
  createdAt     DateTime @default(now())
}

// ---------------------------------------------------------------------------
//  Notifications
// ---------------------------------------------------------------------------
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("info") // info | success | warning | error
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}
